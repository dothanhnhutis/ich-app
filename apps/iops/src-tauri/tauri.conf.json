{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iops",
  "version": "0.1.0",
  "identifier": "com.thanhnhut.iops",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/#/",
        "title": "iOPS - I.C.H Operations System",
        "width": 1280,
        "height": 1440,
        "center": true,
        "visible": false
      },
      {
        "label": "login",
        "url": "/#/login",
        "title": "iOPS - I.C.H Operations System",
        "width": 400,
        "height": 600,
        "center": true,
        "fullscreen": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
